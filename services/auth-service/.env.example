NODE_ENV=development
PORT=4001

# PostgreSQL — auth-service database
DATABASE_URL="postgresql://pms:pms_secret@localhost:5433/pms_auth?schema=public"

# SuperTokens
SUPERTOKENS_URI=http://localhost:3567
SUPERTOKENS_API_KEY=

# Domains
API_DOMAIN=http://localhost:4001
WEBSITE_DOMAIN=http://localhost:3000

# SMTP (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Kafka
KAFKA_BROKER=localhost:9092

# Logging
LOG_LEVEL=info
