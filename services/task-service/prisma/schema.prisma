datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Task {
  id            String   @id @default(uuid())
  projectId     String
  workspaceId   String
  title         String
  description   String?
  status        String   @default("pending")
  priority      String
  dueDate       DateTime
  sprintId      String?
  parentTask    String?
  createdBy     String
  projectHeadId String?
  cycleCount    Int      @default(0)
  isFlagged     Boolean  @default(false)
  flagReason    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignees TaskAssignee[]
  history   TaskHistory[]

  @@index([projectId])
  @@index([sprintId])
  @@index([status])
  @@index([workspaceId])
  @@index([isFlagged])
}

model TaskAssignee {
  id     String @id @default(uuid())
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String
  fromValue String?
  toValue   String?
  note      String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Sprint {
  id        String    @id @default(uuid())
  projectId String
  name      String
  goal      String?
  status    String    @default("planned")   // planned | active | closed
  startDate DateTime
  endDate   DateTime
  startedAt DateTime?
  closedAt  DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@index([status])
}

// Local read model — populated via PROJECT_DEADLINE_EXTENDED events.
model ProjectEndDateCache {
  projectId String   @id
  endDate   DateTime
  updatedAt DateTime @updatedAt
}

// Local read model — populated via PROJECT_MEMBER_ADDED / PROJECT_MEMBER_ROLE_CHANGED events.
// Used by CreateTask to enforce that TL users can only create subtasks.
model ProjectMemberRoleCache {
  projectId String
  userId    String
  role      String
  updatedAt DateTime @updatedAt

  @@id([projectId, userId])
  @@index([projectId])
}

// Blueprint for tasks that repeat on a fixed interval.
// The recurring scheduler creates a new Task from this template every intervalDays.
model RecurringTaskTemplate {
  id            String    @id @default(uuid())
  projectId     String
  workspaceId   String
  title         String
  description   String?
  priority      String
  assignees     String[]
  intervalDays  Int
  nextDueDate   DateTime
  endDate       DateTime?
  projectHeadId String?
  createdBy     String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([nextDueDate])
  @@index([isActive])
}