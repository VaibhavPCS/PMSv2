{
  "name": "@pms/task-service",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev":          "nodemon index.js",
    "start":        "node index.js",
    "test":         "jest",
    "test:watch":   "jest --watch",
    "test:coverage":"jest --coverage",
    "prisma":       "node ./scripts/run-prisma.js",
    "db:migrate":   "node ./scripts/run-prisma.js migrate dev",
    "db:deploy":    "node ./scripts/run-prisma.js migrate deploy",
    "db:studio":    "node ./scripts/run-prisma.js studio",
    "db:generate":  "node ./scripts/run-prisma.js generate"
  },
  "dependencies": {
    "@pms/auth-middleware":  "^1.0.0",
    "@pms/constants":        "^1.0.0",
    "@pms/error-handler":    "^1.0.0",
    "@pms/kafka":            "^1.0.0",
    "@pms/logger":           "^1.0.0",
    "@pms/validators":       "^1.0.0",
    "@prisma/client":        "^5.22.0",
    "cors":                  "^2.8.6",
    "dotenv":                "^17.3.1",
    "express":               "^4.22.1",
    "express-rate-limit":    "^7.4.1",
    "helmet":                "^8.0.0",
    "supertokens-node":      "^9.2.3",
    "swagger-jsdoc":         "^6.2.8",
    "swagger-ui-express":    "^5.0.1"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon":   "^3.1.14",
    "prisma":    "^5.22.0"
  }
}